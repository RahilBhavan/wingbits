{
  "name": "wingbits-cli",
  "version": "0.1.0",
  "description": "Terminal CLI for the Wingbits Customer API — flight tracking, GPS jamming, live watch",
  "license": "MIT",
  "type": "module",
  "bin": {
    "wingbits": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "conf": "^15.0.0",
    "ink": "^5.2.1",
    "ora": "^8.2.0",
    "react": "^18.3.1",
    "wingbits-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.18",
    "@vitest/coverage-v8": "^4.1.4",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "keywords": ["wingbits", "cli", "adsb", "flight-tracking", "depin", "aviation"]
}
